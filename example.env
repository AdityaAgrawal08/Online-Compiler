# Public runtime config
NEXT_PUBLIC_EXECUTOR_URL=https://your-executor-service.example.com
NEXT_PUBLIC_API_KEY=replace-with-public-api-key

# MongoDB (for logged-in user code persistence)
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=online_compiler

# NextAuth + Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
NEXTAUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional access controls (comma-separated)
ALLOWED_EMAILS=
ALLOWED_DOMAINS=
